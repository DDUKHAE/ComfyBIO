{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comfybio.local/schemas/journal-query-set-v1.schema.json",
  "title": "ComfyBIO 저널 자연어 쿼리 데이터셋",
  "description": "저널 벤치마크용 held-out 자연어 쿼리와 평가 참조를 정의한다.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "dataset_id", "status", "frozen", "queries"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "dataset_id": {"const": "comfybio-journal-query-set-v1"},
    "status": {
      "enum": ["draft_schema_only", "seed_draft", "full_draft", "frozen"]
    },
    "frozen": {"type": "boolean"},
    "queries": {
      "type": "array",
      "items": {"$ref": "#/$defs/query_record"}
    }
  },
  "$defs": {
    "query_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "id",
        "label",
        "query",
        "expected_intent",
        "acceptable_template_ids",
        "acceptable_workflow_ids",
        "functional_equivalence_group",
        "difficulty",
        "domain",
        "support_status",
        "input_fixture_id",
        "expected_output_id",
        "source",
        "provenance",
        "leakage_review",
        "notes"
      ],
      "properties": {
        "schema_version": {"const": "1.0.0"},
        "id": {"type": "string", "pattern": "^JQ[0-9]{3}$"},
        "label": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$",
          "minLength": 3,
          "maxLength": 100
        },
        "query": {"type": "string", "minLength": 10, "maxLength": 1000},
        "expected_intent": {
          "enum": [
            "fasta_parse",
            "pairwise_alignment",
            "multiple_alignment",
            "blast_search",
            "searchio_analysis",
            "phylogeny",
            "annotation",
            "pdb_structure_basic",
            "motif_scan_basic",
            "entrez_fetch",
            "uniprot_lookup",
            "kegg_pathway_basic",
            "unsupported"
          ]
        },
        "acceptable_template_ids": {
          "type": "array",
          "items": {"type": "string", "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"},
          "uniqueItems": true
        },
        "acceptable_workflow_ids": {
          "type": "array",
          "items": {"type": "string", "pattern": "^GW_[A-Za-z0-9_]+$"},
          "uniqueItems": true
        },
        "functional_equivalence_group": {
          "type": ["string", "null"],
          "pattern": "^FEG_[A-Za-z0-9_]+$"
        },
        "difficulty": {"enum": ["easy", "medium", "hard", "adversarial"]},
        "domain": {
          "enum": [
            "sequence_io",
            "alignment",
            "similarity_search",
            "phylogeny",
            "annotation",
            "structure",
            "motif",
            "external_database"
          ]
        },
        "support_status": {"enum": ["supported", "unsupported", "ambiguous"]},
        "input_fixture_id": {
          "oneOf": [
            {"type": "string", "pattern": "^FX_[A-Za-z0-9_]+$"},
            {"type": "null"}
          ]
        },
        "expected_output_id": {
          "oneOf": [
            {"type": "string", "pattern": "^OUT_[A-Za-z0-9_]+$"},
            {"type": "null"}
          ]
        },
        "source": {
          "enum": ["independent_contributor", "author_written_heldout", "externally_curated"]
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["author_code", "author_role", "created_at", "development_involvement"],
          "properties": {
            "author_code": {"type": "string", "pattern": "^AUTHOR_[0-9]{2}$"},
            "author_role": {"enum": ["independent_domain_expert", "project_author", "external_curator"]},
            "created_at": {"type": "string", "format": "date-time"},
            "development_involvement": {"type": "boolean"}
          }
        },
        "leakage_review": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "matched_terms", "reviewed_by", "reviewed_at"],
          "properties": {
            "status": {"enum": ["pending", "pass", "flagged"]},
            "matched_terms": {
              "type": "array",
              "items": {"type": "string", "minLength": 1},
              "uniqueItems": true
            },
            "reviewed_by": {
              "oneOf": [
                {"type": "string", "pattern": "^REVIEWER_[0-9]{2}$"},
                {"type": "null"}
              ]
            },
            "reviewed_at": {
              "oneOf": [
                {"type": "string", "format": "date-time"},
                {"type": "null"}
              ]
            }
          }
        },
        "notes": {"type": "string", "maxLength": 2000}
      },
      "allOf": [
        {
          "if": {"properties": {"support_status": {"const": "supported"}}},
          "then": {
            "properties": {
              "acceptable_template_ids": {"minItems": 1},
              "acceptable_workflow_ids": {"minItems": 1},
              "functional_equivalence_group": {"type": "string"},
              "input_fixture_id": {"type": "string"},
              "expected_output_id": {"type": "string"}
            }
          }
        },
        {
          "if": {"properties": {"support_status": {"const": "unsupported"}}},
          "then": {
            "properties": {
              "expected_intent": {"const": "unsupported"},
              "acceptable_template_ids": {"maxItems": 0},
              "acceptable_workflow_ids": {"maxItems": 0},
              "functional_equivalence_group": {"type": "null"},
              "input_fixture_id": {"type": "null"},
              "expected_output_id": {"type": "null"}
            }
          }
        }
      ]
    }
  }
}
